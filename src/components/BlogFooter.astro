---
import {site} from "../consts";
import {getLangFromUrl, t} from '../i18n/utils'
import {formatDate} from "../utils/formatDate";

const {title, date, url} = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<div class="border-l-4 my-4 p-4 border-l-skin-base bg-skin-card break-all">
  {title ? <div>{t('footer.articleTitle', lang)}: {title}</div> : ''}
  {site.author ? <div>{t('footer.articleAuthor', lang)}: {site.author}</div> : ''}
  {date ? <div>{t('footer.releaseTime', lang)}: {formatDate(date, lang)}</div> : ''}
  {
    site.url ? (
      <div>
        {t('footer.originalLink', lang)}: <a href={site.url + '/' + url} class="hover:text-skin-active">{site.url + '/' + url}</a>
      </div>
    ) : ''
  }
</div>
