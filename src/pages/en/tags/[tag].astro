---
import IndexPage from "src/layouts/IndexPage.astro";
import getUniqueTags from "src/utils/getUniqueTags";
import getPostsByTag from "src/utils/getPostsByTag";
import SearchTitle from "src/components/SearchTitle.astro";
import {formatDate} from "../../../utils/formatDate";
import {sortPostsByDate} from "src/utils/sortPostsByDate";
import {getCollectionByName} from "../../../utils/getCollectionByName";
import {getLangFromUrl, localizePath} from "../../../i18n/utils";
export async function getStaticPaths() {
  const posts = await getCollectionByName("blog");
  //   иҝҮж»ӨжІЎжңүеҲҶзұ»зҡ„ж–Үз« пјҢtodo еҗҺжңҹеҸҜиғҪдјҡејәеҲ¶йңҖиҰҒж–Үз« еҲҶзұ?
  const tags = getUniqueTags(posts).filter((tag) => tag);
  return tags.map((tag) => {
    return {params: {tag,}, props: {tag,},};
  });
}
const {tag} = Astro.props;
const lang = getLangFromUrl(Astro.url);
let posts = await getCollectionByName("blog", lang);
const tagPosts = getPostsByTag(posts, tag);
const resultPosts = sortPostsByDate(tagPosts);
---

<IndexPage>
  <SearchTitle label={tag}/>
  <ul class="text-skin-base">
    {
      resultPosts.map((post) => (
        <li style="list-style-type: disc;" class="ml-4 my-2">
          <a href={localizePath('/' + post.collection + '/' + post.slug, lang)}>
            <span class="mr-4">
              {formatDate(post.data.date, lang)}
            </span>
            <span class="hover:text-skin-active">
            {post.data.title}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</IndexPage>
