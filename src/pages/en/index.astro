---
import PostView from '../../components/PostView.astro'
import IndexPage from '../../layouts/IndexPage.astro'
import {getCollectionByName} from "../../utils/getCollectionByName";
import {orderBySticky} from "../../utils/orderBySticky";
import {site} from '../../consts'
import Pagination from "../../components/Pagination.astro";
import {ceil, divide} from 'lodash-es'
import {getLangFromUrl, localizePath} from "../../i18n/utils";

let currentPage = 1
const lang = getLangFromUrl(Astro.url);
let blogs = await getCollectionByName("blog", lang);
let totalPage = ceil(divide(blogs.length, site.postPageSize))

let sortedPosts = await orderBySticky(blogs);
if (sortedPosts.length > site.postPageSize) {
  sortedPosts = sortedPosts.splice(0, site.postPageSize);
}
---

<IndexPage>
  {
    sortedPosts.map(blog =>
      <PostView blog={blog}></PostView>)
  }
  {
    totalPage > 1 ?
      <Pagination
        currentPage={currentPage}
        totalPage={totalPage}
        url={{prev: '', next: localizePath('/blog/2', lang)}}
      /> : ''
  }
</IndexPage>

